# ─────────────────────────────────────────────
#  Pi Agent — Provider API Keys Sample
#  Copy to .env and fill in your keys
#  Usage: source .env && pi
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Kimi For Coding (OpenCode-style provider)
KIMI_API_KEY=sk-...

# Firecrawl (used by pi-pi expert agents for web crawling)
FIRECRAWL_API_KEY=fc-...

# ─────────────────────────────────────────────
#  Research Skill — Exa & Tavily API Keys
#  Add 2-4 keys for each service for rotation
# ─────────────────────────────────────────────

# Exa API Keys (https://dashboard.exa.ai)
EXA_API_KEY_1=
EXA_API_KEY_2=
EXA_API_KEY_3=
EXA_API_KEY_4=

# Tavily API Keys (https://app.tavily.com)
TAVILY_API_KEY_1=
TAVILY_API_KEY_2=
TAVILY_API_KEY_3=
TAVILY_API_KEY_4=
