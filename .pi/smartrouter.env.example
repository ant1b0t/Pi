# SmartRouter provider config for Pi
# Copy to .pi/smartrouter.env and fill in your values.
# This file is read by extensions/provider-smartrouter.ts.

SMARTROUTER_BASE_URL=https://your-smartrouter-host.example
SMARTROUTER_API_KEY=
SMARTROUTER_ADMIN_TOKEN=

# Optional alias accepted by the extension
# SMARTROUTER_URL=https://your-smartrouter-host.example

# Optional transport mode for streaming requests.
# SMARTROUTER_STREAM_TRANSPORT=proxy
# SMARTROUTER_STREAM_TRANSPORT=direct

# Optional proxy settings for SmartRouter only.
# If you use a proxy, the SmartRouter gateway host is auto-added to NO_PROXY by the extension.
# ALL_PROXY=socks5://127.0.0.1:10808
# HTTPS_PROXY=socks5://127.0.0.1:10808
# HTTP_PROXY=socks5://127.0.0.1:10808
# NO_PROXY=127.0.0.1,localhost
