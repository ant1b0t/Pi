# SmartRouter provider config for Pi
# Copy to .pi/smartrouter.env and fill in your values.
# This file is read by extensions/provider-smartrouter.ts.

SMARTROUTER_BASE_URL=https://your-smartrouter-host.example
SMARTROUTER_API_KEY=
SMARTROUTER_ADMIN_TOKEN=

# Optional alias accepted by the extension
# SMARTROUTER_URL=https://your-smartrouter-host.example
